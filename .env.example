# Anthropic API Key
ANTHROPIC_API_KEY=your_api_key_here

# LLM 설정
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.0

# 검색 설정
RETRIEVER_TOP_K=10
RERANKER_TOP_K=5
RETRIEVER_SCORE_THRESHOLD=0.3

# ChromaDB 설정
CHROMA_PERSIST_DIR=./data/vectorstore
CHROMA_COLLECTION_NAME=medrag

# 임베딩 설정
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# 청킹 설정
CHUNK_SIZE=512
CHUNK_OVERLAP=64
